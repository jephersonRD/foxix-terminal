use freetype::Library;
use freetype::Face;
use freetype::freetype;
use freetype::{Bitmap, FtResult, Glyph};
use std::collections::HashMap;

use crate::terminal::buffer::{CellAttributes, ScreenBuffer};
use crate::terminal::cursor::Cursor;
use anyhow::Result;
use gl::types::*;
use std::f32;
use std::ptr;

// Vertex shader
const VERTEX_SHADER: &str = r#"#version 330 core
in vec2 aPosition;
in vec2 aTexCoord;  
in vec4 aColor;

out vec2 TexCoord;
out vec4 VertexColor;

uniform vec2 uCellSize;
uniform vec2 uScreenSize;

void main() {
    vec2 pos = aPosition;
    pos.y = uScreenSize.y - pos.y;
    gl_Position = vec4(
        (pos.x / uScreenSize.x) * 2.0 - 1.0,
        1.0 - (pos.y / uScreenSize.y) * 2.0 - 1.0,
        0.0,
        1.0
    );
    TexCoord = aTexCoord;
    VertexColor = aColor;
}
"#;

// Fragment shader  
const FRAGMENT_SHADER: &str = r#"#version 330 core
in vec2 TexCoord;
in vec4 VertexColor;

out vec4 FragColor;

uniform sampler2D uTexture;
uniform bool uHasTexture;

void main() {
    if (uHasTexture) {
        float alpha = texture(uTexture, TexCoord).r;
        FragColor = vec4(VertexColor.rgb, VertexColor.a * alpha);
    } else {
        FragColor = VertexColor;
    }
}
"#;

pub struct GpuRenderer {
    program: GLuint,
    vao: GLuint,
    vbo: GLuint,
    ebo: GLuint,
    cols: usize,
    rows: usize,
    cell_width: f32,
    cell_height: f32,
    window_width: f32,
    window_height: f32,
    cell_size_loc: GLint,
    screen_size_loc: GLint,
    texture_loc: GLint,
    has_texture_loc: GLint,
    texture_id: GLuint,
    freetype: Option<Library>,
    font_cache: HashMap<char, Glyph>,
    font_size: u32,
    font_face: Option<Face>,
}

impl GpuRenderer {
    pub fn new(
        cell_width: f32,
        cell_height: f32,
        cols: usize,
        rows: usize,
        window_width: u32,
        window_height: u32,
    ) -> Result<Self> {
        // Initialize FreeType
        let freetype_lib = match Library::init() {
            Ok(lib) => Some(lib),
            Err(_) => None,
        };

        unsafe {
            gl::Enable(gl::BLEND);
            gl::BlendFunc(gl::SRC_ALPHA, gl::ONE_MINUS_SRC_ALPHA);

            let program = Self::create_shader_program(VERTEX_SHADER, FRAGMENT_SHADER)?;

            let mut vao: GLuint = 0;
            let mut vbo: GLuint = 0;
            let mut ebo: GLuint = 0;

            gl::GenVertexArrays(1, &mut vao);
            gl::GenBuffers(1, &mut vbo);
            gl::GenBuffers(1, &mut ebo);

            let stride = 8 * std::mem::size_of::<GLfloat>() as GLsizei;
            let offset = |i: usize| (i * std::mem::size_of::<GLfloat>()) as *const _;

            gl::VertexAttribPointer(0, 2, gl::FLOAT, gl::FALSE, stride, offset(0));
            gl::EnableVertexAttribArray(0);
            gl::VertexAttribPointer(1, 2, gl::FLOAT, gl::FALSE, stride, offset(2));
            gl::EnableVertexAttribArray(1);
            gl::VertexAttribPointer(2, 4, gl::FLOAT, gl::FALSE, stride, offset(4));
            gl::EnableVertexAttribArray(2);

            gl::BindVertexArray(vao);
            gl::BindBuffer(gl::ARRAY_BUFFER, vbo);
            gl::BindBuffer(gl::ELEMENT_ARRAY_BUFFER, ebo);

            let mut tex: GLuint = 0;
            gl::GenTextures(1, &mut tex);
            gl::BindTexture(gl::TEXTURE_2D, tex);
            gl::TexParameteri(gl::TEXTURE_2D, gl::TEXTURE_MIN_FILTER, gl::LINEAR as i32);
            gl::TexParameteri(gl::TEXTURE_2D, gl::TEXTURE_MAG_FILTER, gl::LINEAR as i32);
            gl::TexParameteri(gl::TEXTURE_2D, gl::TEXTURE_WRAP_S, gl::CLAMP_TO_EDGE as i32);
            gl::TexParameteri(gl::TEXTURE_2D, gl::TEXTURE_WRAP_T, gl::CLAMP_TO_EDGE as i32);

            let cell_size_loc =
                gl::GetUniformLocation(program, b"uCellSize\0".as_ptr() as *const _);
            let screen_size_loc =
                gl::GetUniformLocation(program, b"uScreenSize\0".as_ptr() as *const _);
            let texture_loc = gl::GetUniformLocation(program, b"uTexture\0".as_ptr() as *const _);
            let has_texture_loc =
                gl::GetUniformLocation(program, b"uHasTexture\0".as_ptr() as *const _);

            Ok(Self {
                program,
                vao,
                vbo,
                ebo,
                cols,
                rows,
                cell_width,
                cell_height,
                window_width: window_width as f32,
                window_height: window_height as f32,
                cell_size_loc,
                screen_size_loc,
                texture_loc,
                has_texture_loc,
                texture_id: tex,
                freetype: freetype_lib,
                font_cache: HashMap::new(),
                font_size: 16,
                font_face: None,
            })
        }
    }
}

unsafe fn create_shader(type_: GLenum, source: &str) -> Result<GLuint> {
    let shader = gl::CreateShader(type_);
    let c_source = std::ffi::CString::new(source).unwrap();
    gl::ShaderSource(shader, 1, &c_source.as_ptr(), std::ptr::null());
    gl::CompileShader(shader);

    let mut status: GLint = 0;
    gl::GetShaderiv(shader, gl::COMPILE_STATUS, &mut status);
    if status == 0 {
        let mut len: GLint = 0;
        gl::GetShaderiv(shader, gl::INFO_LOG_LENGTH, &mut len);
        let mut log = vec![0u8; len as usize];
        gl::GetShaderInfoLog(
            shader,
            len,
            std::ptr::null_mut(),
            log.as_mut_ptr() as *mut _;
        );
        let msg = String::from_utf8_unchecked(log);
        anyhow::bail!("Shader compilation failed: {}", msg);
    }

    Ok(shader)
}

unsafe fn create_shader_program(vs: &str, fs: &str) -> Result<GLuint> {
    let vertex_shader = Self::create_shader(gl::VERTEX_SHADER, vs)?;
    let fragment_shader = Self::create_shader(gl::FRAGMENT_SHADER, fs)?;

    let program = gl::CreateProgram();
    gl::AttachShader(program, vertex_shader);
    gl::AttachShader(program, fragment_shader);
    gl::LinkProgram(program);

    let mut status: GLint = 0;
    gl::GetProgramiv(program, gl::LINK_STATUS, &mut status);
    if status == 0 {
        let mut len: GLint = 0;
        gl::GetProgramiv(program, gl::INFO_LOG_LENGTH, &mut len);
        let mut log = vec![0u8; len as usize];
        gl::GetProgramInfoLog(
            program,
            len,
            std::ptr::null_mut(),
            log.as_mut_ptr() as *mut _;
        );
        let msg = String::from_utf8_unchecked(log);
        anyhow::bail!("Program linking failed: {}", msg);
    }

    gl::DeleteShader(vertex_shader);
    gl::DeleteShader(fragment_shader);

    Ok(program)
}
"#;

